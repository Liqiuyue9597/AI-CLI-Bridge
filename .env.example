# ═══ Discord 配置（可选）═══
# Discord Bot Token (从 https://discord.com/developers/applications 获取)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID
DISCORD_APP_ID=your_application_id_here

# 可选：限制 bot 只在指定 Discord 频道响应（逗号分隔的频道 ID）
# ALLOWED_CHANNELS=123456789,987654321

# ═══ 飞书配置（可选）═══
# 飞书 App ID 和 App Secret (从 https://open.feishu.cn/app 获取)
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_lark_app_secret_here

# 可选：限制 bot 只在指定飞书群聊响应（逗号分隔的 chat ID）
# ALLOWED_LARK_CHATS=oc_xxxxx,oc_yyyyy

# ═══ 安全配置 ═══
# ⚠️ 强烈建议配置用户白名单，限制谁可以使用 Bot（逗号分隔的用户 ID）
# Discord 用户 ID: 开启开发者模式后右键头像复制
# 飞书 Open ID (ou_xxx): 启动 Bot 后发 whoami 获取
# 不配置则所有用户都可以使用
# ALLOWED_USERS=discord_user_id_1,discord_user_id_2,ou_feishu_open_id_1

# 是否跳过 Claude 权限检查（默认 false，即安全模式）
# ⚠️ 设置为 true 会让 Claude 跳过所有权限确认，可执行任意操作！
# 仅在你完全信任所有 ALLOWED_USERS 时才启用
# SKIP_PERMISSIONS=false

# ═══ AI CLI 工具 ═══
# CLI 可执行文件路径（支持 claude / codex / gemini 等）
CLI_PATH=claude

# 工作目录（AI 会在这个目录下操作文件）
CLAUDE_WORK_DIR=/path/to/your/workspace

# 指定模型（可选，和 /model 命令中的名称一致）
# 支持别名: opus, sonnet, haiku, opusplan, sonnet[1m], opus[1m]
# 也支持完整模型名: claude-opus-4-6, claude-sonnet-4-6 等
# 不配置则使用 CLI 默认模型
# CLAUDE_MODEL=opus

# CLI 子进程超时（毫秒），默认 300000（5 分钟）
# CLI_TIMEOUT_MS=300000

# ═══ 速率限制 ═══
# 速率限制时间窗口（毫秒），默认 60000（1 分钟）
# RATE_LIMIT_WINDOW_MS=60000

# 每个时间窗口内允许的最大请求数，默认 5
# RATE_LIMIT_MAX=5
